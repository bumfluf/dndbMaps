{
  "manifest_version": 3,
  "name": "D&D Beyond Extension",
  "version": "1.0.0",
  "description": "A Chrome extension for D&D Beyond",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting",
    "identity"
  ],
  "host_permissions": [
    "https://www.dndbeyond.com/*",
    "https://www.googleapis.com/*",
    "https://drive.google.com/*"
  ],
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "D&D Beyond Extension",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "options_page": "src/options.html",
  "content_scripts": [
    {
      "matches": ["https://www.dndbeyond.com/*"],
      "js": ["src/content.js"]
    }
  ]
}
